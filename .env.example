# Copy to `.env` and customize. Values here are safe defaults.

# Porta HTTP do painel (local-only)
BOOKMARKS_PORT=8765

# Interface de bind. Mantenha em 127.0.0.1 para acesso só da máquina.
BOOKMARKS_HOST=127.0.0.1

# Prefixo dos labels launchd. Use um domínio reverso que você controla
# para não colidir com outros serviços. Ex: com.seunome.bookmarks
BOOKMARKS_LABEL_PREFIX=com.bookmarks.panel

# Nome do app desktop do Cowork (o macOS acha por esse nome via `open -a`).
# Padrão: "Claude" (app oficial da Anthropic).
COWORK_APP=Claude

# Caminho opcional para o HTML de origem. Por padrão usa
# <repo>/relatorio-bookmarks-x.html.
# BOOKMARKS_HTML=/caminho/absoluto/relatorio.html
